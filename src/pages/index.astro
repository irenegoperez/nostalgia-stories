---
import BaseHead from "../components/BaseHead.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import {
	audiences,
	brand,
	editorialGallery,
	eventTypes,
	faqs,
	hero,
	highlights,
	inquiry,
	instagramShowcase,
	portfolioPreview,
	processSteps,
	services,
	visuals,
} from "../data/siteContent";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} image="/assets/nostalgia-stories-logo.jpeg" />
	</head>
	<body>
		<header class="site-header" aria-label="Main navigation">
			<a class="nav-word" href="#inquire">Inquire</a>
			<a class="brand-mark" href="#top" aria-label="Nostalgia Stories home">
				<img src="/assets/nostalgia-stories-logo.jpeg" alt="Nostalgia Stories logo" />
			</a>
			<button class="nav-word menu-trigger" type="button" aria-controls="site-menu" aria-expanded="false" data-menu-trigger>
				Menu
			</button>
		</header>

		<div class="site-menu" id="site-menu" aria-hidden="true" data-site-menu>
			<div class="menu-image">
				<img src={portfolioPreview[1].image} alt="" />
			</div>
			<nav class="menu-panel" aria-label="Expanded navigation">
				<button class="menu-close" type="button" data-menu-close>Close</button>
				<p class="eyebrow">Explore</p>
				<a href="#top" data-menu-link>Home</a>
				<a href="#services" data-menu-link>Services</a>
				<a href="#process" data-menu-link>Process</a>
				<a href="#instagram" data-menu-link>Instagram</a>
				<a href="#faq" data-menu-link>FAQ</a>
				<a href="#inquire" data-menu-link>Inquire</a>
				<div class="menu-social">
					<a href={brand.instagramUrl}>Instagram</a>
					<a href={brand.tiktokUrl}>TikTok</a>
				</div>
			</nav>
		</div>

		<main id="top">
			<section class="hero-canvas" aria-labelledby="hero-title">
				<div class="hero-sticky">
					<div class="hero-shell">
						<div class="hero-center">
							<img class="hero-logo" src="/assets/nostalgia-stories-logo.jpeg" alt="Nostalgia Stories" />
							<p class="hero-script">Wedding content with a soft, social-first point of view.</p>
							<h1 id="hero-title">{hero.title}</h1>
							<p class="hero-intro">{hero.intro}</p>
							<div class="button-row" aria-label="Primary actions">
								<a class="button button-primary" href="#inquire">{hero.primaryCta}</a>
								<a class="button button-secondary" href="#services">{hero.secondaryCta}</a>
							</div>
						</div>

						<figure class="hero-portrait">
							<img src={portfolioPreview[0].image} alt="" />
							<figcaption>
								<span>01</span>
								<span>Soft wedding stories</span>
							</figcaption>
						</figure>

						<div class="hero-footer" aria-label="Event types">
							<span>{brand.location}</span>
							<span>{audiences.slice(0, 3).join(" / ")}</span>
						</div>
					</div>
				</div>
			</section>

			<section class="audience-loop" aria-label="Event types">
				<div class="audience-track">
					{audiences.map((audience) => <span>{audience}</span>)}
					{audiences.map((audience) => <span aria-hidden="true">{audience}</span>)}
				</div>
			</section>

			<section class="brand-statement">
				<img class="statement-image" src={portfolioPreview[3].image} alt="" />
				<div class="statement-overlay"></div>
				<div class="statement-inner section-shell">
					<div class="statement-copy">
						<p class="eyebrow">The feeling first</p>
						<h2>For the candid, cinematic, and social moments that happen between the planned ones.</h2>
						<p>
							We document quick laughs, table details, music shifts, guest reactions, venue atmosphere,
							behind-the-scenes energy, and the quiet pieces that make an event feel personal.
						</p>
					</div>
				</div>
			</section>

			<section id="services" class="services-editorial section-shell">
				<div class="section-kicker">
					<p class="eyebrow">What we create</p>
					<h2>Content made to post, share, and relive.</h2>
				</div>
				<ol class="service-ledger">
					{services.map((service, index) => (
						<li>
							<span>{String(index + 1).padStart(2, "0")}</span>
							<h3>{service.title}</h3>
							<p>{service.description}</p>
						</li>
					))}
				</ol>
			</section>

			<section class="gallery-showcase" aria-labelledby="gallery-title">
				<div class="gallery-intro section-shell">
					<div>
						<p class="eyebrow">Seen in motion</p>
						<h2 id="gallery-title">A moving lookbook of the soft, pretty moments we chase.</h2>
					</div>
					<p>
						Wedding mornings, florals, tablescapes, champagne, guest reactions, and the tiny details that
						make the final edit feel feminine, warm, and alive.
					</p>
					<div class="gallery-actions" aria-label="Gallery controls">
						<button type="button" aria-label="Previous gallery images" data-gallery-prev>&lsaquo;</button>
						<button type="button" aria-label="Next gallery images" data-gallery-next>&rsaquo;</button>
					</div>
				</div>
				<div class="editorial-gallery" aria-label="Wedding content preview gallery" tabindex="0" data-editorial-gallery>
					<div class="editorial-gallery-track">
						{[...editorialGallery, ...editorialGallery].map((item, index) => (
							<figure class="gallery-card" aria-hidden={index >= editorialGallery.length ? "true" : "false"}>
								<img src={item.image} alt="" />
								<figcaption>
									<span>{item.number}</span>
									<strong>{item.title}</strong>
									<small>{item.label}</small>
								</figcaption>
							</figure>
						))}
					</div>
				</div>
			</section>

			<section id="process" class="process-scroll">
				<div class="process-sticky section-shell">
					<div class="process-media-stack" aria-hidden="true">
						<img class="process-image process-image-one" src={portfolioPreview[1].image} alt="" />
						<img class="process-image process-image-two" src={visuals.heroPhone} alt="" />
						<img class="process-image process-image-three" src={instagramShowcase.items[2].image} alt="" />
					</div>
					<div class="process-copy">
						<p class="eyebrow">How it works</p>
						<h2>A calm process from first inquiry to final delivery.</h2>
						<div class="process-steps">
							{processSteps.map((item) => (
								<article>
									<span>{item.step}</span>
									<div>
										<h3>{item.title}</h3>
										<p>{item.description}</p>
									</div>
								</article>
							))}
						</div>
					</div>
				</div>
			</section>

			<section class="memory-note section-shell">
				<p class="eyebrow">Nostalgia note</p>
				<blockquote>
					"We focus on the moments people feel but do not always see: the movement, the atmosphere,
					the details, and the story already unfolding in the room."
				</blockquote>
				<ul class="highlight-line">
					{highlights.map((highlight) => <li>{highlight}</li>)}
				</ul>
			</section>

			<section id="instagram" class="instagram-ribbon">
				<div class="instagram-inner section-shell">
					<div class="instagram-copy">
						<p class="eyebrow">{instagramShowcase.eyebrow}</p>
						<h2>{instagramShowcase.title}</h2>
						<p>{instagramShowcase.intro}</p>
						<a class="button button-secondary" href={brand.instagramUrl}>{instagramShowcase.cta}</a>
					</div>
					<div class="instagram-rail" aria-label={`${brand.instagramHandle} preview`} tabindex="0">
						{instagramShowcase.items.map((item) => (
							<article class="instagram-frame">
								<img src={item.image} alt="" />
								<div>
									<span>{item.label}</span>
									<h3>{item.title}</h3>
								</div>
							</article>
						))}
					</div>
				</div>
			</section>

			<section id="faq" class="faq-section section-shell">
				<div class="section-kicker">
					<p class="eyebrow">Good to know</p>
					<h2>Questions clients usually ask first.</h2>
				</div>
				<div class="faq-list">
					{faqs.map((faq) => (
						<details>
							<summary>{faq.question}</summary>
							<p>{faq.answer}</p>
						</details>
					))}
				</div>
			</section>

			<section id="inquire" class="inquiry-section section-shell">
				<div class="inquiry-copy">
					<p class="eyebrow">{inquiry.eyebrow}</p>
					<h2>{inquiry.title}</h2>
					<p>{inquiry.intro}</p>
					<p>{inquiry.responseTime}</p>
				</div>

				<form class="inquiry-form" data-inquiry-form data-inquiry-email={brand.email}>
					<div class="form-grid">
						<label>
							<span>Your name</span>
							<input name="name" type="text" autocomplete="name" required />
						</label>
						<label>
							<span>Email</span>
							<input name="email" type="email" autocomplete="email" required />
						</label>
						<label>
							<span>Phone or WhatsApp</span>
							<input name="phone" type="tel" autocomplete="tel" />
						</label>
						<label>
							<span>Instagram or TikTok handle</span>
							<input name="social" type="text" placeholder="@nostalgiastories" />
						</label>
						<div class="form-field">
							<span>Event type</span>
							<div class="custom-select" data-custom-select>
								<button class="custom-select-trigger" type="button" aria-haspopup="listbox" aria-expanded="false">
									<span data-custom-select-label>Select one</span>
									<span aria-hidden="true">+</span>
								</button>
								<input data-custom-select-input name="eventType" type="hidden" />
								<div class="custom-select-menu" role="listbox" aria-label="Event type">
									{eventTypes.map((eventType) => (
										<button type="button" role="option" data-value={eventType} aria-selected="false">
											{eventType}
										</button>
									))}
								</div>
								<p class="field-error">Please choose an event type.</p>
							</div>
						</div>
						<label>
							<span>Event date</span>
							<input name="eventDate" type="date" />
						</label>
						<label class="field-wide">
							<span>Location or venue</span>
							<input name="location" type="text" placeholder="City, venue, or destination" />
						</label>
					</div>

					<fieldset>
						<legend>What content are you looking for?</legend>
						<label><input name="contentNeeds" type="checkbox" value="Vertical 4K iPhone coverage" /> Vertical 4K iPhone coverage</label>
						<label><input name="contentNeeds" type="checkbox" value="Ready-to-post reels" /> Ready-to-post reels</label>
						<label><input name="contentNeeds" type="checkbox" value="Raw clips" /> Raw clips</label>
						<label><input name="contentNeeds" type="checkbox" value="Drone filler shots" /> Drone filler shots</label>
						<label><input name="contentNeeds" type="checkbox" value="Restaurant or brand content" /> Restaurant or brand content</label>
						<label><input name="contentNeeds" type="checkbox" value="Not sure yet" /> Not sure yet</label>
					</fieldset>

					<div class="form-grid">
						<label>
							<span>Estimated coverage</span>
							<select name="coverage">
								<option value="">Select one</option>
								<option>2-4 hours</option>
								<option>5-6 hours</option>
								<option>Full event day</option>
								<option>Multi-day event</option>
								<option>Not sure yet</option>
							</select>
						</label>
						<label>
							<span>How did you hear about us?</span>
							<input name="referral" type="text" />
						</label>
						<label class="field-wide">
							<span>Tell us about the vision</span>
							<textarea name="vision" rows="6" placeholder="Share the mood, must-capture moments, music direction, timeline notes, or anything you want the content to feel like."></textarea>
						</label>
						<label class="field-wide">
							<span>Inspiration links</span>
							<input name="inspiration" type="text" placeholder="Instagram, TikTok, Pinterest, or website links" />
						</label>
					</div>

					<button class="button button-primary" type="submit">Send inquiry</button>
				</form>
			</section>
		</main>

		<footer class="site-footer">
			<p>{brand.name} - {brand.tagline}</p>
			<p>Copyright 2026</p>
		</footer>
		<script>
			const menu = document.querySelector("[data-site-menu]");
			const menuTrigger = document.querySelector("[data-menu-trigger]");
			const menuClose = document.querySelector("[data-menu-close]");
			const menuLinks = document.querySelectorAll("[data-menu-link]");

			const setMenu = (isOpen) => {
				if (!(menu instanceof HTMLElement) || !(menuTrigger instanceof HTMLElement)) {
					return;
				}

				menu.classList.toggle("is-open", isOpen);
				menu.setAttribute("aria-hidden", String(!isOpen));
				menuTrigger.setAttribute("aria-expanded", String(isOpen));
				document.body.classList.toggle("menu-open", isOpen);
			};

			menuTrigger?.addEventListener("click", () => setMenu(true));
			menuClose?.addEventListener("click", () => setMenu(false));
			menuLinks.forEach((link) => link.addEventListener("click", () => setMenu(false)));

			document.addEventListener("keydown", (event) => {
				if (event.key === "Escape") {
					setMenu(false);
				}
			});

			const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

			const galleryViewport = document.querySelector("[data-editorial-gallery]");
			const galleryPrev = document.querySelector("[data-gallery-prev]");
			const galleryNext = document.querySelector("[data-gallery-next]");

			if (galleryViewport instanceof HTMLElement) {
				let galleryPaused = false;
				let galleryFrame = 0;

				const resetGalleryLoop = () => {
					const midpoint = galleryViewport.scrollWidth / 2;

					if (midpoint > 0 && galleryViewport.scrollLeft >= midpoint) {
						galleryViewport.scrollLeft -= midpoint;
					}
				};

				const moveGallery = () => {
					if (!galleryPaused && !reducedMotion) {
						galleryViewport.scrollLeft += 0.42;
						resetGalleryLoop();
					}

					galleryFrame = window.requestAnimationFrame(moveGallery);
				};

				const scrollGallery = (direction) => {
					galleryPaused = true;
					galleryViewport.scrollBy({
						left: direction * Math.min(galleryViewport.clientWidth * 0.78, 560),
						behavior: reducedMotion ? "auto" : "smooth",
					});
					window.setTimeout(() => {
						galleryPaused = false;
					}, 1200);
				};

				galleryViewport.addEventListener("mouseenter", () => {
					galleryPaused = true;
				});

				galleryViewport.addEventListener("mouseleave", () => {
					galleryPaused = false;
				});

				galleryViewport.addEventListener("focusin", () => {
					galleryPaused = true;
				});

				galleryViewport.addEventListener("focusout", () => {
					galleryPaused = false;
				});

				galleryViewport.addEventListener("scroll", resetGalleryLoop, { passive: true });
				galleryPrev?.addEventListener("click", () => scrollGallery(-1));
				galleryNext?.addEventListener("click", () => scrollGallery(1));
				galleryFrame = window.requestAnimationFrame(moveGallery);

				window.addEventListener("beforeunload", () => window.cancelAnimationFrame(galleryFrame));
			}

			const customSelect = document.querySelector("[data-custom-select]");

			if (customSelect instanceof HTMLElement) {
				const trigger = customSelect.querySelector(".custom-select-trigger");
				const label = customSelect.querySelector("[data-custom-select-label]");
				const input = customSelect.querySelector("[data-custom-select-input]");
				const options = customSelect.querySelectorAll("[data-value]");

				const closeSelect = () => {
					customSelect.classList.remove("is-open");
					trigger?.setAttribute("aria-expanded", "false");
				};

				trigger?.addEventListener("click", () => {
					const isOpen = customSelect.classList.toggle("is-open");
					trigger.setAttribute("aria-expanded", String(isOpen));
				});

				options.forEach((option) => {
					option.addEventListener("click", () => {
						const value = option.getAttribute("data-value") || "";

						if (input instanceof HTMLInputElement) {
							input.value = value;
						}

						if (label) {
							label.textContent = value;
						}

						options.forEach((item) => item.setAttribute("aria-selected", "false"));
						option.setAttribute("aria-selected", "true");
						customSelect.classList.add("has-value");
						customSelect.classList.remove("is-invalid");
						closeSelect();
					});
				});

				document.addEventListener("click", (event) => {
					const target = event.target;

					if (!(target instanceof Node) || !customSelect.contains(target)) {
						closeSelect();
					}
				});
			}

			const inquiryForm = document.querySelector("[data-inquiry-form]");

			if (inquiryForm instanceof HTMLFormElement) {
				inquiryForm.addEventListener("submit", (event) => {
					event.preventDefault();

					const data = new FormData(inquiryForm);
					const eventType = data.get("eventType") || "";

					if (!eventType && customSelect instanceof HTMLElement) {
						customSelect.classList.add("is-invalid");
						customSelect.scrollIntoView({ behavior: "smooth", block: "center" });
						return;
					}

					const contentNeeds = data.getAll("contentNeeds").join(", ") || "Not selected";
					const recipient = inquiryForm.dataset.inquiryEmail || "hello@nostalgiastories.co";
					const lines = [
						"New Nostalgia Stories inquiry",
						"",
						`Name: ${data.get("name") || ""}`,
						`Email: ${data.get("email") || ""}`,
						`Phone or WhatsApp: ${data.get("phone") || ""}`,
						`Instagram or TikTok: ${data.get("social") || ""}`,
						`Event type: ${eventType}`,
						`Event date: ${data.get("eventDate") || ""}`,
						`Location or venue: ${data.get("location") || ""}`,
						`Content needs: ${contentNeeds}`,
						`Estimated coverage: ${data.get("coverage") || ""}`,
						`Referral: ${data.get("referral") || ""}`,
						"",
						"Vision:",
						`${data.get("vision") || ""}`,
						"",
						"Inspiration links:",
						`${data.get("inspiration") || ""}`,
					];

					const subject = encodeURIComponent("Nostalgia Stories inquiry");
					const body = encodeURIComponent(lines.join("\n"));
					window.location.href = `mailto:${recipient}?subject=${subject}&body=${body}`;
				});
			}
		</script>
	</body>
</html>
