---
import BaseHead from "../components/BaseHead.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import {
	audiences,
	brand,
	eventTypes,
	faqs,
	hero,
	highlights,
	inquiry,
	instagramShowcase,
	portfolioPreview,
	processSteps,
	services,
	visuals,
} from "../data/siteContent";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} image="/assets/nostalgia-stories-logo.jpeg" />
	</head>
	<body>
		<header class="site-header" aria-label="Main navigation">
			<a class="brand-mark" href="#top" aria-label="Nostalgia Stories home">
				<img src="/assets/nostalgia-stories-logo.jpeg" alt="Nostalgia Stories logo" />
			</a>
			<nav>
				<a href="#services">Services</a>
				<a href="#process">Process</a>
				<a href="#faq">FAQ</a>
				<a href="#inquire">Inquire</a>
			</nav>
		</header>

		<main id="top">
			<section class="hero-section section-shell">
				<div class="hero-copy">
					<p class="eyebrow">{hero.eyebrow}</p>
					<h1>{hero.title}</h1>
					<p class="hero-intro">{hero.intro}</p>
					<div class="button-row" aria-label="Primary actions">
						<a class="button button-primary" href="#inquire">{hero.primaryCta}</a>
						<a class="button button-secondary" href="#services">{hero.secondaryCta}</a>
					</div>
				</div>

				<div class="hero-media" aria-label="Nostalgia Stories brand preview">
					<div class="phone-frame phone-frame-main">
						<div class="phone-screen">
							<span class="clip-label">4K vertical</span>
							<img class="phone-photo" src={visuals.heroPhone} alt="" />
							<p>Social-ready stories with a soft, cinematic eye.</p>
						</div>
					</div>
					<div class="phone-frame phone-frame-small" aria-hidden="true">
						<div class="phone-screen">
							<span class="clip-label">Drone filler</span>
							<img class="phone-photo" src={visuals.heroMini} alt="" />
							<p>Details, atmosphere, and motion between the big moments.</p>
						</div>
					</div>
				</div>
			</section>

			<section class="marquee-band" aria-label="Event types">
				<div>
					{audiences.map((audience) => <span>{audience}</span>)}
				</div>
			</section>

			<section class="intro-section section-shell">
				<div>
					<p class="eyebrow">The feeling first</p>
					<h2>For the candid, cinematic, and social moments that happen between the planned ones.</h2>
				</div>
				<div class="intro-copy">
					<p>
						We document the movement of the day: quick laughs, table details, music shifts,
						venue atmosphere, guest reactions, behind-the-scenes energy, and the quiet pieces
						that make an event feel personal.
					</p>
					<ul class="check-list">
						{highlights.map((highlight) => <li>{highlight}</li>)}
					</ul>
				</div>
			</section>

			<section class="portfolio-strip" aria-label="Portfolio preview">
				{portfolioPreview.map((item) => (
					<div class="reel-card" style={`--reel-image: url("${item.image}")`}>
						<span>{item.label}</span>
					</div>
				))}
			</section>

			<section id="services" class="services-section section-shell">
				<div class="section-heading">
					<p class="eyebrow">What we create</p>
					<h2>Content made to post, share, and relive.</h2>
				</div>
				<div class="service-grid">
					{services.map((service) => (
						<article>
							<h3>{service.title}</h3>
							<p>{service.description}</p>
						</article>
					))}
				</div>
			</section>

			<section id="process" class="process-section section-shell">
				<div class="section-heading">
					<p class="eyebrow">How it works</p>
					<h2>A calm process from first inquiry to final delivery.</h2>
				</div>
				<div class="process-grid">
					{processSteps.map((item) => (
						<article>
							<span>{item.step}</span>
							<h3>{item.title}</h3>
							<p>{item.description}</p>
						</article>
					))}
				</div>
			</section>

			<section class="testimonial-section section-shell">
				<p class="eyebrow">Nostalgia note</p>
				<blockquote>
					"We focus on the moments people feel but do not always see - the movement, the
					atmosphere, the details, and the story already unfolding in the room."
				</blockquote>
			</section>

			<section class="instagram-section">
				<div class="instagram-inner section-shell">
					<div class="instagram-copy">
						<p class="eyebrow">{instagramShowcase.eyebrow}</p>
						<h2>{instagramShowcase.title}</h2>
						<p>{instagramShowcase.intro}</p>
						<a class="button button-secondary" href={brand.instagramUrl}>{instagramShowcase.cta}</a>
					</div>
					<div class="instagram-grid" aria-label={`${brand.instagramHandle} preview`}>
						{instagramShowcase.items.map((item) => (
							<article class="instagram-card">
								<img src={item.image} alt="" />
								<div>
									<span>{item.label}</span>
									<h3>{item.title}</h3>
								</div>
							</article>
						))}
					</div>
				</div>
			</section>

			<section id="faq" class="faq-section section-shell">
				<div class="section-heading">
					<p class="eyebrow">Good to know</p>
					<h2>Questions clients usually ask first.</h2>
				</div>
				<div class="faq-list">
					{faqs.map((faq) => (
						<details>
							<summary>{faq.question}</summary>
							<p>{faq.answer}</p>
						</details>
					))}
				</div>
			</section>

			<section id="inquire" class="inquiry-section section-shell">
				<div class="inquiry-copy">
					<p class="eyebrow">{inquiry.eyebrow}</p>
					<h2>{inquiry.title}</h2>
					<p>{inquiry.intro}</p>
					<p>{inquiry.responseTime}</p>
				</div>

				<form class="inquiry-form" data-inquiry-form data-inquiry-email={brand.email}>
					<div class="form-grid">
						<label>
							<span>Your name</span>
							<input name="name" type="text" autocomplete="name" required />
						</label>
						<label>
							<span>Email</span>
							<input name="email" type="email" autocomplete="email" required />
						</label>
						<label>
							<span>Phone or WhatsApp</span>
							<input name="phone" type="tel" autocomplete="tel" />
						</label>
						<label>
							<span>Instagram or TikTok handle</span>
							<input name="social" type="text" placeholder="@nostalgiastories" />
						</label>
						<div class="form-field">
							<span>Event type</span>
							<div class="custom-select" data-custom-select>
								<button class="custom-select-trigger" type="button" aria-haspopup="listbox" aria-expanded="false">
									<span data-custom-select-label>Select one</span>
									<span aria-hidden="true">+</span>
								</button>
								<input data-custom-select-input name="eventType" type="hidden" />
								<div class="custom-select-menu" role="listbox" aria-label="Event type">
									{eventTypes.map((eventType) => (
										<button type="button" role="option" data-value={eventType} aria-selected="false">
											{eventType}
										</button>
									))}
								</div>
								<p class="field-error">Please choose an event type.</p>
							</div>
						</div>
						<label>
							<span>Event date</span>
							<input name="eventDate" type="date" />
						</label>
						<label class="field-wide">
							<span>Location or venue</span>
							<input name="location" type="text" placeholder="City, venue, or destination" />
						</label>
					</div>

					<fieldset>
						<legend>What content are you looking for?</legend>
						<label><input name="contentNeeds" type="checkbox" value="Vertical 4K iPhone coverage" /> Vertical 4K iPhone coverage</label>
						<label><input name="contentNeeds" type="checkbox" value="Ready-to-post reels" /> Ready-to-post reels</label>
						<label><input name="contentNeeds" type="checkbox" value="Raw clips" /> Raw clips</label>
						<label><input name="contentNeeds" type="checkbox" value="Drone filler shots" /> Drone filler shots</label>
						<label><input name="contentNeeds" type="checkbox" value="Restaurant or brand content" /> Restaurant or brand content</label>
						<label><input name="contentNeeds" type="checkbox" value="Not sure yet" /> Not sure yet</label>
					</fieldset>

					<div class="form-grid">
						<label>
							<span>Estimated coverage</span>
							<select name="coverage">
								<option value="">Select one</option>
								<option>2-4 hours</option>
								<option>5-6 hours</option>
								<option>Full event day</option>
								<option>Multi-day event</option>
								<option>Not sure yet</option>
							</select>
						</label>
						<label>
							<span>How did you hear about us?</span>
							<input name="referral" type="text" />
						</label>
						<label class="field-wide">
							<span>Tell us about the vision</span>
							<textarea name="vision" rows="6" placeholder="Share the mood, must-capture moments, music direction, timeline notes, or anything you want the content to feel like."></textarea>
						</label>
						<label class="field-wide">
							<span>Inspiration links</span>
							<input name="inspiration" type="text" placeholder="Instagram, TikTok, Pinterest, or website links" />
						</label>
					</div>

					<button class="button button-primary" type="submit">Send inquiry</button>
				</form>
			</section>
		</main>

		<footer class="site-footer">
			<p>{brand.name} - {brand.tagline}</p>
			<p>Copyright 2026</p>
		</footer>
		<script>
			const customSelect = document.querySelector("[data-custom-select]");

			if (customSelect instanceof HTMLElement) {
				const trigger = customSelect.querySelector(".custom-select-trigger");
				const label = customSelect.querySelector("[data-custom-select-label]");
				const input = customSelect.querySelector("[data-custom-select-input]");
				const options = customSelect.querySelectorAll("[data-value]");

				const closeSelect = () => {
					customSelect.classList.remove("is-open");
					trigger?.setAttribute("aria-expanded", "false");
				};

				trigger?.addEventListener("click", () => {
					const isOpen = customSelect.classList.toggle("is-open");
					trigger.setAttribute("aria-expanded", String(isOpen));
				});

				options.forEach((option) => {
					option.addEventListener("click", () => {
						const value = option.getAttribute("data-value") || "";

						if (input instanceof HTMLInputElement) {
							input.value = value;
						}

						if (label) {
							label.textContent = value;
						}

						options.forEach((item) => item.setAttribute("aria-selected", "false"));
						option.setAttribute("aria-selected", "true");
						customSelect.classList.add("has-value");
						customSelect.classList.remove("is-invalid");
						closeSelect();
					});
				});

				document.addEventListener("click", (event) => {
					const target = event.target;

					if (!(target instanceof Node) || !customSelect.contains(target)) {
						closeSelect();
					}
				});

				document.addEventListener("keydown", (event) => {
					if (event.key === "Escape") {
						closeSelect();
					}
				});
			}

			const inquiryForm = document.querySelector("[data-inquiry-form]");

			if (inquiryForm instanceof HTMLFormElement) {
				inquiryForm.addEventListener("submit", (event) => {
					event.preventDefault();

					const data = new FormData(inquiryForm);
					const eventType = data.get("eventType") || "";

					if (!eventType && customSelect instanceof HTMLElement) {
						customSelect.classList.add("is-invalid");
						customSelect.scrollIntoView({ behavior: "smooth", block: "center" });
						return;
					}

					const contentNeeds = data.getAll("contentNeeds").join(", ") || "Not selected";
					const recipient = inquiryForm.dataset.inquiryEmail || "hello@nostalgiastories.co";
					const lines = [
						"New Nostalgia Stories inquiry",
						"",
						`Name: ${data.get("name") || ""}`,
						`Email: ${data.get("email") || ""}`,
						`Phone or WhatsApp: ${data.get("phone") || ""}`,
						`Instagram or TikTok: ${data.get("social") || ""}`,
						`Event type: ${eventType}`,
						`Event date: ${data.get("eventDate") || ""}`,
						`Location or venue: ${data.get("location") || ""}`,
						`Content needs: ${contentNeeds}`,
						`Estimated coverage: ${data.get("coverage") || ""}`,
						`Referral: ${data.get("referral") || ""}`,
						"",
						"Vision:",
						`${data.get("vision") || ""}`,
						"",
						"Inspiration links:",
						`${data.get("inspiration") || ""}`,
					];

					const subject = encodeURIComponent("Nostalgia Stories inquiry");
					const body = encodeURIComponent(lines.join("\n"));
					window.location.href = `mailto:${recipient}?subject=${subject}&body=${body}`;
				});
			}
		</script>
	</body>
</html>
